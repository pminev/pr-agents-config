# Example configuration for the agentic PR pipeline.
#
# These map to GitHub Actions repo/org VARIABLES (Settings → Secrets and
# variables → Actions → Variables), not secrets. API keys go in SECRETS instead
# (see README). Copy the relevant values into your repo's variables.

# Which agent CLI the self-hosted runner invokes: claude | qwen | antigravity
AGENT_CLI=claude

# Optional model override passed to the CLI. Leave empty to use the CLI default.
# Ignored when USE_OLLAMA=true (the model comes from Ollama — see OLLAMA_MODEL).
AGENT_MODEL=

# --- Local model via Ollama ---
# Run the SAME agent CLI (claude / qwen) against a local model with
# `ollama launch <tool>` instead of a cloud API. No API key needed.
USE_OLLAMA=false
# Which local model Ollama serves (must be pulled: `ollama pull <model>`).
OLLAMA_MODEL=qwen2.5-coder:14b
# Ollama server address (default is Ollama's own default; set if remote/custom).
OLLAMA_HOST=

# Require a label before running? "true" (default) runs only on labeled issues;
# "false" runs on every newly opened issue.
AGENT_REQUIRE_LABEL=true

# Label that triggers a run when AGENT_REQUIRE_LABEL=true.
AGENT_TRIGGER_LABEL=agent

# Hard cap on the whole job (minutes) and on the agent step (seconds).
AGENT_TIMEOUT_MINUTES=45
AGENT_TIMEOUT=2400

# --- Secrets (set these under Settings → Secrets, NOT variables) ---
# Provide the one(s) your chosen AGENT_CLI needs:
#   ANTHROPIC_API_KEY         Claude Code via Anthropic API
#   CLAUDE_CODE_OAUTH_TOKEN   Claude Code via a Pro/Max subscription
#   GEMINI_API_KEY            Qwen Code / Gemini-based CLIs
#   QWEN_API_KEY              Qwen Code (DashScope)
